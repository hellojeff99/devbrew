generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int              @id @default(autoincrement())
  email       String           @unique
  password    String
  name        String
  role        UserRole
  headline    String?
  bio         String?
  techStack   String[]
  createdAt   DateTime         @default(now())
  menteeChats CoffeeChat[]     @relation("MenteeChats")
  mentorChats CoffeeChat[]     @relation("MentorChats")
  mentorSlots MentorTimeSlot[]
  messages    Message[]
}

model MentorTimeSlot {
  id         Int         @id @default(autoincrement())
  mentorId   Int
  startTime  DateTime
  isReserved Boolean     @default(false)
  createdAt  DateTime    @default(now())
  coffeeChat CoffeeChat?
  mentor     User        @relation(fields: [mentorId], references: [id])
}

model CoffeeChat {
  id         Int              @id @default(autoincrement())
  mentorId   Int
  menteeId   Int
  timeSlotId Int              @unique
  status     CoffeeChatStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  chatRoom   ChatRoom?
  mentee     User             @relation("MenteeChats", fields: [menteeId], references: [id])
  mentor     User             @relation("MentorChats", fields: [mentorId], references: [id])
  timeSlot   MentorTimeSlot   @relation(fields: [timeSlotId], references: [id])
}

model ChatRoom {
  id           Int        @id @default(autoincrement())
  coffeeChatId Int        @unique
  createdAt    DateTime   @default(now())
  coffeeChat   CoffeeChat @relation(fields: [coffeeChatId], references: [id])
  messages     Message[]
}

model Message {
  id         Int      @id @default(autoincrement())
  chatRoomId Int
  senderId   Int
  content    String
  createdAt  DateTime @default(now())
  chatRoom   ChatRoom @relation(fields: [chatRoomId], references: [id])
  sender     User     @relation(fields: [senderId], references: [id])
}

enum UserRole {
  MENTOR
  MENTEE
}

enum CoffeeChatStatus {
  PENDING
  APPROVED
  REJECTED
}
